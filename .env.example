# ============================================
# Adbullet Daily Reports — environment config
# Copy to .env locally; set as variables on Railway
# ============================================

# --- Server ---
PORT=3000
NODE_ENV=production
TZ=Asia/Kolkata

# --- Postgres (Railway auto-injects DATABASE_URL when you attach Postgres plugin) ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Admin UI Basic Auth ---
ADMIN_USER=admin
ADMIN_PASS=change-me-please

# --- Windsor.ai ---
# Get your API key from https://windsor.ai → Settings → API
WINDSOR_API_KEY=your-windsor-api-key-here

# --- Email (Gmail SMTP) ---
# 1. Enable 2-step verification on your Google account
# 2. Create an app password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-char password below (no spaces)
GMAIL_USER=gopalvserve@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
FROM_NAME=Adbullet Reports
REPLY_TO=gopalvserve@gmail.com

# --- Cron schedule ---
# Default: 8:00 AM IST every day  ->  "30 2 * * *" in UTC
DAILY_CRON=30 2 * * *
CRON_ENABLED=true

# --- Optional: BCC every report (comma-separated) ---
INTERNAL_BCC=gopalvserve@gmail.com
