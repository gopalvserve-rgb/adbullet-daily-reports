<%- include('_header', { page: page }) %>
<h1>Dashboard</h1>

<div class="stats">
  <div class="stat"><div class="stat-label">Total clients</div><div class="stat-value"><%= stats.totalClients %></div></div>
  <div class="stat"><div class="stat-label">Active</div><div class="stat-value"><%= stats.activeClients %></div></div>
  <div class="stat"><div class="stat-label">Connected accounts</div><div class="stat-value"><%= stats.totalAccounts %></div></div>
  <div class="stat"><div class="stat-label">Sends in last 7d</div><div class="stat-value"><%= stats.sendsLast7d %></div></div>
</div>

<div class="actions-row">
  <form method="POST" action="/admin/run-now" style="display:inline-block;"><button class="btn primary">▶ Run all now</button></form>
  <a class="btn" href="/admin/clients/new">+ Add client</a>
  <a class="btn ghost" href="/admin/check-email" target="_blank">Test Gmail SMTP</a>
</div>

<h2>Recent sends</h2>
<table class="data">
  <thead><tr><th>When</th><th>Client</th><th>Date</th><th>Status</th><th>Duration</th><th>Notes</th></tr></thead>
  <tbody>
  <% recent.forEach(function(r){ %>
    <tr>
      <td><%= new Date(r.sent_at).toLocaleString('en-IN', {timeZone:'Asia/Kolkata'}) %></td>
      <td><%= r.client_name %></td>
      <td><%= r.report_date %></td>
      <td><span class="pill <%= r.status %>"><%= r.status %></span></td>
      <td><%= r.duration_ms ? (r.duration_ms + ' ms') : '—' %></td>
      <td class="muted"><%= r.error_message || '' %></td>
    </tr>
  <% }); %>
  <% if (!recent.length) { %><tr><td colspan="6" class="muted">No sends yet.</td></tr><% } %>
  </tbody>
</table>
<%- include('_footer') %>
